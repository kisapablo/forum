<button class="collapse-button collapse-color" type="button" data-toggle="collapse" data-target="#toolbarCollapse"
    aria-expanded="false" aria-controls="toolbarCollapse">
    <img class="collapse-ico" src="/public/images/default_ico/favicon.png" alt="Hello">
    <span>Toolbar</span>
</button>
<div class="collapse" id="toolbarCollapse">
    <div class="collapse_settings">

        <div class="post-toolbar post-header">
            {% include 'Navigation/pagination.twig' with pagination %}
            {# Мб будет так-же в форм поиска#}
            <form method="get" action="{{ url('posts?') }}" class="search-header">
                <label class="toolbar-search-body">
                    <span class="search-title">Поиск</span>
                    <input type="search" class="search-form" name="search" placeholder="Search">
                    <input type="search" class="search-form" name="author" placeholder="Search with author_id">
                    <select name="tags" id="tags" class="search-form">
                        <option selected>Very tag</option>
                        <option>This Tag</option>
                    </select>
                    <button type="submit" class="nav-button builder-color">Search</button>
                </label>
            </form>
        </div>
    </div>
</div>
